{
    "name": "@kleinkram/backend-common",
    "version": "0.58.0",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "license": "MIT",
    "scripts": {
        "build": "tsc -b && tsc-alias -p tsconfig.json",
        "seed:run": "ts-node --project tsconfig.json -r tsconfig-paths/register src/scripts/run-seed.ts"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.js"
        },
        "./*": {
            "types": "./dist/*.d.ts",
            "import": "./dist/*.js",
            "require": "./dist/*.js"
        }
    },
    "peerDependencies": {
        "@nestjs/common": "^11.0.0",
        "@nestjs/core": "^11.0.0",
        "@nestjs/typeorm": "^11.0.0",
        "typeorm": "^0.3.0"
    },
    "dependencies": {
        "@kleinkram/api-dto": "workspace:*",
        "@kleinkram/shared": "workspace:*",
        "@kleinkram/validation": "workspace:*",
        "@nestjs/schedule": "^5.0.1",
        "@willsoto/nestjs-prometheus": "^6.0.2",
        "axios": "^1.13.2",
        "bull": "^4.16.4",
        "fs-extra": "^11.3.2",
        "jsonwebtoken": "^9.0.2",
        "minimatch": "^10.1.1",
        "minio": "8.0.6",
        "pg": "^8.16.3",
        "prom-client": "^15.1.3",
        "qs": "^6.14.0",
        "rxjs": "^7.8.2",
        "typeorm-extension": "^3.7.3"
    },
    "devDependencies": {
        "@faker-js/faker": "^10.1.0",
        "@nestjs/common": "^11.1.9",
        "@nestjs/core": "^11.1.11",
        "@nestjs/typeorm": "^11.0.0",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "^24.10.1",
        "ts-node": "^10.9.1",
        "tsc-alias": "^1.8.16",
        "tsconfig-paths": "^4.2.0",
        "typeorm": "^0.3.27",
        "typescript": "^5.9.3"
    }
}
