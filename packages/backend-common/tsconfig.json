{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "rootDir": "src",
        "baseUrl": ".",
        "outDir": "dist",
        "paths": {
            "@backend-common/*": ["src/*"],
            "@kleinkram/api-dto": ["../api-dto/src/index.ts"],
            "@kleinkram/api-dto/*": ["../api-dto/src/*"],
            "@kleinkram/shared": ["../shared/src/index.ts"],
            "@kleinkram/shared/*": ["../shared/src/*"],
            "@kleinkram/validation": ["../validation/src/index.ts"],
            "@kleinkram/validation/*": ["../validation/src/*"]
        },
        "types": ["node"]
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", "dist"],
    "references": [
        {
            "path": "../api-dto"
        },
        {
            "path": "../shared"
        },
        {
            "path": "../validation"
        }
    ]
}
