{
    "name": "@kleinkram/api-dto",
    "version": "0.60.0",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "license": "MIT",
    "scripts": {
        "build": "tsc -b && tsc-alias -p tsconfig.json",
        "clean": "rm -rf dist"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.js"
        },
        "./*": {
            "types": "./dist/*.d.ts",
            "import": "./dist/*.js",
            "require": "./dist/*.js"
        }
    },
    "dependencies": {
        "@kleinkram/shared": "workspace:*",
        "@kleinkram/validation": "workspace:*",
        "@mcap/core": "^2.1.7",
        "@nestjs/swagger": "^11.2.3",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.3",
        "fs-extra": "^11.3.2",
        "minimatch": "^10.1.1",
        "qs": "^6.14.0"
    },
    "devDependencies": {
        "tsc-alias": "^1.8.16",
        "typescript": "^5.9.3"
    }
}
