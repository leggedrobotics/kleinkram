{
    "name": "@kleinkram/validation",
    "version": "0.58.0",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "license": "MIT",
    "scripts": {
        "build": "tsc -b",
        "clean": "rm -rf dist"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.js"
        },
        "./*": {
            "types": "./dist/*.d.ts",
            "import": "./dist/*.js",
            "require": "./dist/*.js"
        }
    },
    "dependencies": {
        "@kleinkram/shared": "workspace:*",
        "@nestjs/swagger": "^11.2.3",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.3"
    },
    "devDependencies": {
        "@nestjs/common": "^11.1.9",
        "typescript": "^5.9.3"
    }
}
