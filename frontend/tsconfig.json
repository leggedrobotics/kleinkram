{
    "extends": "./.quasar/tsconfig.json",
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "src/*": ["src/*"],
            "app/*": ["*"],
            "components/*": ["src/components/*"],
            "layouts/*": ["src/layouts/*"],
            "pages/*": ["src/pages/*"],
            "assets/*": ["src/assets/*"],
            "boot/*": ["src/boot/*"],
            "stores/*": ["src/stores/*"]
        },
        "forceConsistentCasingInFileNames": true
    },
    "references": [
        {
            "path": "../packages/shared"
        },
        {
            "path": "../packages/api-dto"
        },
        {
            "path": "../packages/validation"
        }
    ]
}
